# Prerequisites
*.d

# Compiled Object files
*.slo
*.lo
*.o
*.obj

# Precompiled Headers
*.gch
*.pch

# Linker files
*.ilk

# Debugger Files
*.pdb

# Compiled Dynamic libraries
*.so
*.dylib
*.dll
*.so.*


# Fortran module files
*.mod
*.smod

# Compiled Static libraries
*.lai
*.la
*.a
*.lib

# Executables
*.exe
*.out
*.app

# CMake / compiler output trees (preset uses Output/<presetName>); ignore legacy names
Output/
Build/
build/
build-*/

# CMake generated files
CMakeFiles/
CMakeCache.txt
cmake_install.cmake
Makefile
install_manifest.txt
compile_commands.json

# Secrets — never commit
.env
.env.local
.venv

# Python / data outputs
StockData/*.duckdb

# Temporary files
*.tmp
*.log
*.bak
*.swp

# vcpkg
vcpkg_installed/

# debug information files
*.dwo

# test output & cache
Testing/
.cache/

# Superpowers brainstorm visual companion (local-only mockups)
.superpowers/

# Shell scripts (untracked by default). Exception: root `RunTest.sh` is intended to be committed.
*.sh
!RunTest.sh
