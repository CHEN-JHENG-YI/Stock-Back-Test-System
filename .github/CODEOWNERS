# CODEOWNERS — who reviews what.
#
# Last matching pattern wins. Keep specific paths near the bottom.
#
# Replace @TBD-* placeholders with real GitHub usernames or team handles
# (e.g. @your-org/engine-team) once the team is provisioned.
#
# Branch protection on `main` should require CODEOWNER review for the matched
# files in addition to the universal "1 review approval" rule.

# Default: anything not otherwise matched goes to the repo lead.
*                              @TBD-repo-lead

# Specs and ADRs require an architecture-aware reviewer.
/Docs/Specs/                   @TBD-repo-lead @TBD-architect
/Docs/Decisions/               @TBD-repo-lead @TBD-architect
/Docs/Governance/AGENTS.md     @TBD-repo-lead @TBD-architect
/AGENTS.md                     @TBD-repo-lead @TBD-architect

# Skills changes (coding rules) need lead approval — they affect every PR.
/.cursor/                      @TBD-repo-lead

# CI / build / packaging — anyone touching these can break everyone's day.
/.github/                      @TBD-repo-lead @TBD-build-owner
/Cmake/                        @TBD-build-owner
/CMakeLists.txt                @TBD-build-owner
/CMakePresets.json             @TBD-build-owner
/RunTest.sh                    @TBD-build-owner
/vcpkg.json                    @TBD-build-owner
/Packaging/                    @TBD-build-owner
/tools/                        @TBD-build-owner

# Backend modules — each has a primary owner; default to lead if unset.
/Src/Backend/Core/          @TBD-engine-owner
/Src/Backend/Data/          @TBD-data-owner
/Src/Backend/Indicators/    @TBD-engine-owner
/Src/Backend/Strategy/      @TBD-engine-owner
/Src/Backend/Engine/        @TBD-engine-owner
/Src/Backend/Metrics/       @TBD-engine-owner
/Src/Backend/Bindings/      @TBD-frontend-owner
/Src/Frontend/              @TBD-frontend-owner
/Src/App/                   @TBD-frontend-owner
/Src/Launcher/              @TBD-build-owner
/Src/Plugins/               @TBD-engine-owner

# Tests
/Tests/Determinism/            @TBD-engine-owner @TBD-repo-lead
/Tests/                        @TBD-repo-lead

# Python data pipeline
/DataFetcher/                  @TBD-data-owner

# Sensitive paths — second pair of eyes always.
/Tests/sanitizer-suppressions.txt           @TBD-repo-lead
/tools/symbolAudit.exemptions.yaml          @TBD-repo-lead
/tools/mutation.exemptions.yaml             @TBD-repo-lead
/.env.example                               @TBD-repo-lead
/Docs/Governance/CHANGELOG.md               @TBD-repo-lead
/Docs/Governance/LICENSE                    @TBD-repo-lead
/Docs/Governance/CONTRIBUTING.md            @TBD-repo-lead
